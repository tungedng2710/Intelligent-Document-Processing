# ── Environment Variables for IDP Pipeline ──────────────────────────────────────

# ── LLM Configuration ──────────────────────────────────────────────────────────
# Choose LLM engine: "ollama" or "vllm"
LLM_ENGINE=ollama

# Ollama server URL (used when LLM_ENGINE=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# VLLM server URL (used when LLM_ENGINE=vllm)
VLLM_BASE_URL=http://localhost:9888

# LLM model name
LLM_MODEL=qwen3.5:2b-bf16

# LLM parameters
LLM_TIMEOUT=300
LLM_TEMPERATURE=0
LLM_THINK=false

# ── OCR Configuration ──────────────────────────────────────────────────────────
# OCR engine: "marker" (default) or "ollama"
OCR_ENGINE=marker

# Force OCR even on searchable PDFs (marker engine)
OCR_FORCE_OCR=false

# OCR model (only used when OCR_ENGINE=ollama)
OCR_MODEL=deepseek-ocr:3b-bf16

# OCR parameters
OCR_TIMEOUT=300
OCR_TEMPERATURE=0

# ── API Server Configuration ───────────────────────────────────────────────────
# Host and ports for the API servers
API_HOST=0.0.0.0
OCR_API_PORT=7871
LLM_API_PORT=7872
WRAPPER_API_PORT=7873

# URLs for the wrapper API to call internal services
OCR_API_URL=http://0.0.0.0:7871
LLM_API_URL=http://0.0.0.0:7872